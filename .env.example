# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Razorpay ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# Server-only
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_CURRENCY=INR
NEXT_PUBLIC_RAZORPAY_COMPANY_NAME=Lurevi
NEXT_PUBLIC_RAZORPAY_THEME_COLOR=#0d9488

# ─── Meta Pixel ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=1905415970060955

# ─── Delhivery ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_USE_SUPABASE_DELHIVERY_PROXY=true
# Server-only
DELHIVERY_API_TOKEN=your-delhivery-token
NEXT_PUBLIC_DELHIVERY_CLIENT_NAME=

# ─── Cloudflare Turnstile ─────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_ENABLED=false
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_THEME=light

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://lurevi.in

# ─── Email (server-only — never use NEXT_PUBLIC_) ─────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Lurevi
EMAIL_FROM_EMAIL=
